# ============================================================
# BharatMonitor — Environment Variables
# Copy this to .env.local and fill in your keys
# ============================================================

# ── Supabase (required) ───────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase service key (server-side only, set via CLI) ──────
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your-key
# NEVER put this in .env.local — it bypasses RLS

# ============================================================
# FREE AI APIs — Both are completely free, no credit card
# ============================================================

# ── Gemini (FREE — primary AI) ────────────────────────────────
# Sign up: aistudio.google.com → Get API key → FREE
# Limits: 15 req/min, 1M tokens/day (Gemini Flash)
# Powers: AI brief, contradiction engine, quick scan summaries
# supabase secrets set GEMINI_API_KEY=your-key
GEMINI_API_KEY=

# ── Groq (FREE — fast fallback AI) ───────────────────────────
# Sign up: console.groq.com → Create API key → FREE
# Limits: 14,400 req/day on llama3-8b-8192
# Powers: Fast classification, fallback for all AI features
# supabase secrets set GROQ_API_KEY=your-key
GROQ_API_KEY=

# ── Hugging Face (FREE — Indian language sentiment) ───────────
# Sign up: huggingface.co → Settings → Access Tokens → FREE
# Powers: Hindi/Malayalam/Tamil sentiment analysis (MuRIL model)
# supabase secrets set HUGGINGFACE_API_KEY=your-key
HUGGINGFACE_API_KEY=

# ============================================================
# FREE DATA SOURCES — No API key needed at all
# ============================================================
# These work out of the box, zero configuration:
#
# ✓ Nitter RSS         — Twitter/X data via public instances
# ✓ Google News RSS    — news.google.com/rss (free, no key)
# ✓ GDELT API          — gdeltproject.org (free, no key)
# ✓ Google Trends RSS  — trends.google.com (free, no key)
# ✓ 20+ Indian RSS     — NDTV, Hindu, ANI, PIB, Bhaskar etc.
# ✓ YouTube Data API   — 10K units/day free (see below)

# ============================================================
# OPTIONAL ENHANCEMENTS
# ============================================================

# ── YouTube Data API v3 (FREE — 10K units/day) ───────────────
# Sign up: console.cloud.google.com → Enable YouTube Data API v3
# TIP: Create 3 Google projects = 30K units/day free
# supabase secrets set YOUTUBE_API_KEY=your-key
YOUTUBE_API_KEY=

# ── SerpAPI (optional — better Google Trends data) ───────────
# Sign up: serpapi.com → FREE 100 searches/month
# Without this key, we use the free Trends RSS fallback
# supabase secrets set SERPAPI_KEY=your-key
SERPAPI_KEY=

# ── LibreTranslate (optional — translation for regional langs) ─
# Option A: Use public instance libretranslate.com (free, rate-limited)
# Option B: Self-host — github.com/LibreTranslate/LibreTranslate
# Without this, we display content in original language only
# supabase secrets set LIBRETRANSLATE_URL=https://libretranslate.com
# supabase secrets set LIBRETRANSLATE_KEY=your-key (optional)
LIBRETRANSLATE_URL=
LIBRETRANSLATE_KEY=

# ── Upstash Redis (optional — caching, deduplication) ────────
# Sign up: upstash.com → Create database → FREE 10K req/day
# supabase secrets set UPSTASH_REDIS_REST_URL=your-url
# supabase secrets set UPSTASH_REDIS_REST_TOKEN=your-token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Resend Email (optional — email alerts) ────────────────────
# Sign up: resend.com → FREE 3,000 emails/month
# supabase secrets set RESEND_API_KEY=your-key
RESEND_API_KEY=

# ============================================================
# PAID UPGRADES (when you're ready to scale)
# ============================================================
# These are NOT needed to run BharatMonitor — only add when
# you have paying clients and need higher quality/volume

# Anthropic Claude  — console.anthropic.com  — $50-150/month
# ANTHROPIC_API_KEY=

# Twitter/X Basic   — developer.twitter.com  — $100/month flat
# TWITTER_BEARER_TOKEN=

# Google Translate  — cloud.google.com       — $20/1M chars
# GOOGLE_TRANSLATE_API_KEY=
