# ============================================================
# BharatMonitor — Environment Variables Template
# Copy this to .env.local and fill in real values
# NEVER commit .env.local to git
# ============================================================

# ── Supabase (core) ──────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
VITE_SUPABASE_SERVICE_KEY=eyJhbGci...   # Add in Vercel only, never in code

# ── Google Custom Search → X.com tweets ──────────────────────
VITE_GOOGLE_CSE_KEY=AIza...
VITE_GOOGLE_CSE_CX=xxxxxxxxxxxxxxxx:xxxxxxxxxx

# ── SerpAPI (fallback for Google CSE) ────────────────────────
VITE_SERP_API_KEY=...

# ── YouTube Data API v3 ──────────────────────────────────────
VITE_YOUTUBE_KEY=AIza...

# ── Meta / Instagram / Facebook ──────────────────────────────
VITE_META_ACCESS_TOKEN=EAF...

# ── Sentry (error monitoring) ────────────────────────────────
VITE_SENTRY_DSN=https://...@sentry.io/...

# ── Hugging Face ─────────────────────────────────────────────
VITE_HUGGINGFACE_KEY=hf_...

# ── Resend (email alerts) ────────────────────────────────────
VITE_RESEND_KEY=re_...

# ── Upstash Redis (caching) ──────────────────────────────────
VITE_UPSTASH_REDIS_REST_URL=https://...upstash.io
VITE_UPSTASH_REDIS_REST_TOKEN=...

# ── DEV ONLY: Direct Anthropic key for local contradiction checking ──
# Remove before committing. In production, use the edge function.
# VITE_ANTHROPIC_KEY_DEV=sk-ant-...
